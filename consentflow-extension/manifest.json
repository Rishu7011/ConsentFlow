{
  "manifest_version": 3,
  "name": "ConsentFlow Privacy Shield",
  "version": "1.0.0",
  "description": "Masks your PII before it reaches any AI chatbot.",
  "permissions": ["storage", "activeTab", "scripting"],
  "host_permissions": [
    "https://chat.openai.com/*",
    "https://claude.ai/*"
  ],
  "background": {
    "service_worker": "dist/serviceWorker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://chat.openai.com/*",
        "https://claude.ai/*"
      ],
      "js": ["dist/content/index.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup/index.html",
    "default_icon": {
      "16": "icons/shield.png",
      "48": "icons/shield.png",
      "128": "icons/shield.png"
    }
  },
  "icons": {
    "16": "icons/shield.png",
    "48": "icons/shield.png",
    "128": "icons/shield.png"
  }
}
